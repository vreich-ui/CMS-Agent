# ============================================================================
# LibreChat agent-cockpit environment template.
# Copy to `.env` (same directory) and fill in. NEVER commit the real .env.
#   cp .env.example .env
# Generate the encryption/search secrets with:  ./scripts/gen-secrets.sh
# ============================================================================

# ── Domain / TLS ─────────────────────────────────────────────────────────────
# The domain you control and point (A/AAAA record) at the VM's static IP.
DOMAIN=chat.example.com
# Email Let's Encrypt uses for expiry notices.
ACME_EMAIL=you@example.com
# LibreChat's own notion of its public origin (used for links/CORS). Must be https.
DOMAIN_CLIENT=https://chat.example.com
DOMAIN_SERVER=https://chat.example.com

# ── Encryption / auth secrets (REQUIRED — generate fresh, never reuse examples) ─
# CREDS_KEY  = 32 bytes hex (64 chars)   -> openssl rand -hex 32
# CREDS_IV   = 16 bytes hex (32 chars)   -> openssl rand -hex 16
# JWT_SECRET / JWT_REFRESH_SECRET = 32 bytes hex each
CREDS_KEY=
CREDS_IV=
JWT_SECRET=
JWT_REFRESH_SECRET=

# ── Registration control ─────────────────────────────────────────────────────
# Bring the stack up ONCE with ALLOW_REGISTRATION=true, create your account in the
# browser, then set this to false and `docker compose up -d` again to lock it down.
ALLOW_REGISTRATION=true
ALLOW_EMAIL_LOGIN=true
ALLOW_SOCIAL_LOGIN=false

# ── Model providers (multi-provider is a hard requirement) ───────────────────
# Server-side keys so agents can switch provider per agent. Keys are env-only.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_KEY=

# ── Datastores (managed by docker-compose; leave as-is) ──────────────────────
# compose overrides these to the service DNS names (mongodb / meilisearch); the
# values here are the standalone defaults and are only used outside compose.
MONGO_URI=mongodb://127.0.0.1:27017/LibreChat
SEARCH=true
MEILI_HOST=http://meilisearch:7700
MEILI_NO_ANALYTICS=true
# 16+ byte master key -> openssl rand -base64 32
MEILI_MASTER_KEY=

# ── MCP server credentials (consumed by librechat.yaml ${...} placeholders) ──
# cms-agent-gcloud: bearer token accepted by the Cloud Run MCP endpoint.
CMS_AGENT_KEY=
# promoter: full URL (https://<host>/mcp) + the X-Promoter-Key value.
PROMOTER_MCP_URL=
PROMOTER_KEY=
# monetizer: token for the monetizer MCP endpoint (default header Authorization: Bearer).
MONETIZER_KEY=

# ── Caddy DNS-01 TLS (default path; keeps port 80 closed at the firewall) ────
# Cloudflare API token scoped to Zone:DNS:Edit for your zone. If your DNS is not
# on Cloudflare, swap the module in Dockerfile.caddy and the directive in Caddyfile.
# Leave blank ONLY if you switched Caddyfile to the HTTP-01 path (open :80).
CLOUDFLARE_API_TOKEN=
