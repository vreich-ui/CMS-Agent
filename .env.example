OPENAI_API_KEY=
OPENAI_AGENT_MODEL=gpt-5.5

AGENT_API_TOKEN=
MCP_API_TOKEN=
ADMIN_EMAIL_IDS=

# MCP Authorization (OAuth) for remote connectors such as Claude.
# Secret a human enters on the /oauth/authorize consent screen to approve a connection.
# Falls back to MCP_API_TOKEN when unset; set a dedicated value in production.
MCP_OAUTH_APPROVAL_SECRET=
# When "true", every non-initialize MCP request must carry a valid Mcp-Session-Id (strict session
# enforcement). Defaults to false so stateless bearer callers keep working.
MCP_REQUIRE_SESSION=false
# Where OAuth/session state (clients, codes, tokens, sessions) is stored. It MUST be durable across
# invocations for the remote OAuth flow to work — register and authorize hit different function
# instances. Defaults to Netlify Blobs automatically when a Blobs context is present, so this is
# normally left unset. Values: "blobs" | "memory" (memory is dev/test only).
MCP_STATE_STORE=
# Optional catalog scoping for MCP connectors: comma-separated tool namespaces to expose, e.g.
# "workspace,node,project,workflow". Unset exposes the full catalog (100+ tools). Unexposed tools
# are neither listed nor callable.
MCP_EXPOSED_TOOL_PREFIXES=

# External project MCP connections (resolved at request time; never persisted).
# One <CLIENT>_MCP_ENDPOINT / <CLIENT>_MCP_TOKEN pair per connected MCP server. Set the values in the
# Netlify deployment; only the env var NAMES live in code, so no secrets are ever persisted.
DR_LURIE_MCP_ENDPOINT=
DR_LURIE_MCP_TOKEN=
# Operator gate for LIVE publishing to a project's real site (workflow.publish_run). Default OFF.
# A real publish additionally requires the caller to pass approved:true and live:true; with this
# unset (or not "true") workflow.publish_run only returns a dry-run plan and calls nothing external.
# The flag name is <PREFIX>_PUBLISH_ENABLED, derived from the connection endpoint var, e.g.
# DR_LURIE_MCP_ENDPOINT -> DR_LURIE_PUBLISH_ENABLED. Set to "true" only when you intend live posts.
DR_LURIE_PUBLISH_ENABLED=

# PDF-Tool MCP — server-side artifact/PDF/image generation.
PDF_TOOL_MCP_ENDPOINT=
PDF_TOOL_MCP_TOKEN=

# Snoocle MCP — audio-to-song-data foundry.
SNOOCLE_MCP_ENDPOINT=
SNOOCLE_MCP_TOKEN=

# Monetizer MCP — affiliate/monetization intelligence.
MONETIZER_MCP_ENDPOINT=
MONETIZER_MCP_TOKEN=
