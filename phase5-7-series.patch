+# Model-ladder ENFORCEMENT (docs/platform/DIRECTION.md Phase 7). When "true"/"1"/"on", the conductor
+# applies the cheapest model whose rubric pass-rate clears the threshold (from recorded eval results)
+# for each node at dispatch time. Default OFF — the ladder stays advisory (optimizer.status) unless
+# enabled. It is a per-run override, never a persisted workspace mutation, so turning it off fully
+# reverts. Overrides the model NAME only; ensure each node's eval-attributed candidate models are
+# reachable via that node's provider before enabling.
+IMPROVEMENT_MODEL_LADDER_ENFORCE=false
+# Optional tuning for enforcement. Threshold is a 0..1 pass-rate (default 0.7); min-samples is the
+# minimum evaluated outputs before a model may be enforced (default 3). A model is only enforced when
+# it clears the threshold over at least this many samples. (optimizer.status uses the 0.7/3 defaults.)
+IMPROVEMENT_MODEL_LADDER_THRESHOLD=0.7
+IMPROVEMENT_MODEL_LADDER_MIN_SAMPLES=3
+
